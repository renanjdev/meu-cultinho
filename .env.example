# Copie este arquivo para .env.local (gitignored) e preencha com os dados do seu
# projeto Supabase: Dashboard → Project Settings → API.
#
# A anon key é pública por design (o Row Level Security protege os dados).

EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...sua-anon-key...
